{
  "name": "klevby-smoke-tests",
  "private": true,
  "version": "1.0.0",
  "description": "Minimal Playwright smoke tests for Klevby.com",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "build:web": "npm run vendor:maplibre && npm run sync:www",
    "sync:www": "node scripts/sync-www.mjs",
    "prepare:android": "npm run build:web && npx cap sync android",
    "prepare:ios": "npm run sync:www && npx cap sync ios",
    "vendor:maplibre": "node scripts/vendor-maplibre.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.2"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/ios": "^7.4.2",
    "@playwright/test": "^1.54.2",
    "typescript": "^6.0.3"
  }
}
